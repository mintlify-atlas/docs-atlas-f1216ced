  "keyFeatures": [
    "AI-powered adaptive lessons with grade-specific content (K-12)",
    "Multi-role system (Admin, Parent, Learner) with parent dashboards",
    "Gamification with points, achievements, and parent-managed rewards",
    "Concept mastery tracking with spaced repetition",
    "Real-time progress monitoring and analytics",
    "SVG illustration generation for educational content",
    "Parent-as-learner mode to preview child experience",
    "Database sync for external data backup",
    "Open source AI prompts for transparency"
  ],
  "publicApiSurface": [
    "POST /register - User registration",
    "POST /login - User authentication",
    "GET /api/learners - List learners for parent",
    "POST /api/learners - Create new learner",
    "POST /api/lessons/create - Generate AI lesson",
    "GET /api/lessons/active - Get active lesson",
    "POST /api/lessons/:lessonId/answer - Submit quiz answers",
    "GET /api/learner/:learnerId/concept-performance - Concept mastery data",
    "GET /api/points/balance - Learner point balance",
    "POST /api/rewards/redeem/:rewardId - Redeem reward",
    "GET /api/achievements - User achievements",
    "GET /api/reports - Progress reports",
    "GET /api/export - Export learner data",
    "POST /api/sync-configs - Configure database sync"
  ]
